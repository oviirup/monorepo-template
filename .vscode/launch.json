{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "debug apps/web",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev -- --inspect",
      "cwd": "${workspaceFolder}/apps/web",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s"
      }
    }
  ]
}
