{
  "name": "monorepo-root",
  "version": "1.3.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "biome format --write",
    "lint": "turbo run lint --parallel"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  }
}
